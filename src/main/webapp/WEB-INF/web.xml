<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">
    <display-name>DuAnTotNghiep_Nhom4</display-name>

	<filter>
	    <filter-name>EncodingFilter</filter-name>
	    <filter-class>com.nhom4.hotel.filter.EncodingFilter</filter-class>
	</filter>
	
	<filter-mapping>
	    <filter-name>EncodingFilter</filter-name>
	    <url-pattern>/*</url-pattern>
	</filter-mapping>
	
	<filter>
	    <filter-name>LoginFilter</filter-name>
	    <filter-class>com.nhom4.hotel.filter.LoginFilter</filter-class>
	</filter>
	
	<filter-mapping>
	    <filter-name>LoginFilter</filter-name>
	    <url-pattern>/bookings</url-pattern>
	    <url-pattern>/booking/*</url-pattern>
	    <url-pattern>/admin/*</url-pattern>
	    <url-pattern>/checkout</url-pattern>
	    <url-pattern>/invoices</url-pattern>
	</filter-mapping>

    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/login</url-pattern>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RoomServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.RoomServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RoomServlet</servlet-name>
        <url-pattern>/rooms</url-pattern>
        <url-pattern>/room/detail</url-pattern>
        <url-pattern>/admin/rooms</url-pattern>
        <url-pattern>/admin/rooms/form</url-pattern>
        <url-pattern>/admin/rooms/save</url-pattern>
        <url-pattern>/admin/rooms/delete</url-pattern>
    </servlet-mapping>

    <!-- TẠM COMMENT: chưa có LoaiPhongServlet.java, sẽ mở lại khi teammate code xong
    <servlet>
        <servlet-name>LoaiPhongServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.LoaiPhongServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoaiPhongServlet</servlet-name>
        <url-pattern>/admin/types</url-pattern>
        <url-pattern>/admin/types/save</url-pattern>
        <url-pattern>/admin/types/delete</url-pattern>
    </servlet-mapping>
    -->

    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.BookingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/booking/create</url-pattern>
        <url-pattern>/bookings</url-pattern>
        <url-pattern>/booking/status</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BookingManagementServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.BookingManagementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingManagementServlet</servlet-name>
        <url-pattern>/admin/bookings</url-pattern>
        <url-pattern>/admin/bookings/status</url-pattern>
    </servlet-mapping>

    <!-- TẠM COMMENT: chưa có CheckoutServlet.java, sẽ mở lại khi teammate code xong
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/checkout</url-pattern>
        <url-pattern>/invoices</url-pattern>
    </servlet-mapping>
    -->

    <!-- TẠM COMMENT: chưa có ReportServlet.java, sẽ mở lại khi teammate code xong
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.nhom4.hotel.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/admin/reports</url-pattern>
    </servlet-mapping>
    -->
    
    <servlet>
	    <servlet-name>PaymentServlet</servlet-name>
	    <servlet-class>com.nhom4.hotel.servlet.PaymentServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>PaymentServlet</servlet-name>
	    <url-pattern>/invoices</url-pattern>
	</servlet-mapping>
	
	<servlet>
	    <servlet-name>CheckInServlet</servlet-name>
	    <servlet-class>com.nhom4.hotel.servlet.CheckInServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>CheckInServlet</servlet-name>
	    <url-pattern>/checkin</url-pattern>
	</servlet-mapping>
	
	<servlet>
	    <servlet-name>CheckOutServlet</servlet-name>
	    <servlet-class>com.nhom4.hotel.servlet.CheckOutServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>CheckOutServlet</servlet-name>
	    <url-pattern>/checkout</url-pattern>
	</servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>